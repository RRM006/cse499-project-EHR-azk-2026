# Copy this file to  backend/.env  and fill in your real key.
# backend/.env is gitignored and must NEVER be committed.
# Get a free key at https://aistudio.google.com/apikey

# --- Active correction provider (swappable: gemini | groq | openrouter) ---
CORRECTION_PROVIDER=gemini

# Which model to use for correction. Default is the moving "latest" alias.
# To pin a specific version instead, comment the line below and uncomment one example.
CORRECTION_MODEL=gemini-flash-latest
# CORRECTION_MODEL=gemini-2.5-flash        # pinned Flash (stable, recommended for reproducibility)
# CORRECTION_MODEL=gemini-2.5-flash-lite   # cheaper/faster, higher free RPM
# CORRECTION_MODEL=gemini-2.0-flash        # older generation, if you need it

# --- Gemini (OpenAI-compatible endpoint) ---
# Paste your real key here ONLY in backend/.env (this .example file stays blank).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Correction fallback providers (optional; leave blank in Module 1) ---
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# NOTE: Module 1 uses the browser Web Speech API for speech-to-text (client-side),
# so there is no STT provider configuration here. Other STT engines may be added
# back in a later module.
