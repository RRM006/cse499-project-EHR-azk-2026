# Copy this file to  backend/.env  and fill in your real key.
# backend/.env is gitignored and must NEVER be committed.
# Get a free key at https://aistudio.google.com/apikey

# --- Active correction provider (swappable: gemini | groq | openrouter) ---
CORRECTION_PROVIDER=gemini

# Which model to use for correction. Default is the moving "latest" alias.
# To pin a specific version instead, comment the line below and uncomment one example.
CORRECTION_MODEL=gemini-flash-latest
# CORRECTION_MODEL=gemini-2.5-flash        # pinned Flash (stable, recommended for reproducibility)
# CORRECTION_MODEL=gemini-2.5-flash-lite   # cheaper/faster, higher free RPM
# CORRECTION_MODEL=gemini-2.0-flash        # older generation, if you need it

# --- Gemini (OpenAI-compatible endpoint) ---
# Paste your real key here ONLY in backend/.env (this .example file stays blank).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Correction fallback providers (optional; leave blank in Module 1) ---
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# --- Speech-to-text source ---
# Module 1 uses the browser Web Speech API (client-side), so this is just a label
# today. It is a seam for future swappable STT engines (e.g. faster-whisper).
STT_PROVIDER=browser_webspeech

# --- Persistence ---
# Full SQLAlchemy URL for the database. Leave BLANK to use the default local SQLite
# file (backend/prescreener.db). Schema changes are applied by Alembic migrations
# automatically at startup, so you never have to delete the DB.
# Example for Postgres later:  postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=

# Where generated .docx (and later PDF) files are written. Leave BLANK to use the
# default (backend/data/documents). Point this at any folder or mounted volume in
# deployment — nothing is hardcoded. (Legacy name DOCUMENTS_DIR is still accepted.)
DOCUMENT_OUTPUT_PATH=
