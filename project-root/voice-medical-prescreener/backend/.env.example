# Copy this file to  backend/.env  and fill in your real key.
# backend/.env is gitignored and must NEVER be committed.
# Get a free key at https://aistudio.google.com/apikey

# --- Active correction provider (swappable: gemini | groq | openrouter) ---
CORRECTION_PROVIDER=gemini

# Which model to use for correction. Default is the moving "latest" alias.
# To pin a specific version instead, comment the line below and uncomment one example.
CORRECTION_MODEL=gemini-flash-latest
# CORRECTION_MODEL=gemini-2.5-flash        # pinned Flash (stable, recommended for reproducibility)
# CORRECTION_MODEL=gemini-2.5-flash-lite   # cheaper/faster, higher free RPM
# CORRECTION_MODEL=gemini-2.0-flash        # older generation, if you need it

# --- Gemini (OpenAI-compatible endpoint) ---
# Paste your real key here ONLY in backend/.env (this .example file stays blank).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Correction fallback provider (optional) ---
# OPENROUTER_API_KEY=

# ============================================================================
#  STT (speech-to-text) providers
# ============================================================================
# Which provider the frontend dropdown selects by default.
STT_DEFAULT_PROVIDER=browser_webspeech
# Language hint for server-side STT engines.
STT_LANGUAGE=bn

# --- Groq Whisper (cloud STT; OpenAI-compatible). Free key: https://console.groq.com/keys
# Leave blank → the Groq provider shows "Not Configured" in the dropdown.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3

# --- Local engines (only used after the matching requirements-*.txt is installed;
#     all model weights AUTO-DOWNLOAD from Hugging Face on first use — see INSTALL.md) ---

# Local Whisper (requirements-whisper.txt). faster-whisper size: tiny|base|small|medium
WHISPER_MODEL_SIZE=base

# BanglaSpeech2Text (requirements-banglaspeech.txt). Picks shhossain/whisper-<size>-bn.
BANGLASPEECH_MODEL_SIZE=base     # tiny|base|small
# BANGLASPEECH_MODEL=             # optional: full HF id to override the size mapping

# Qwen3-ASR (requirements-qwen.txt).
# LEAVE THIS BLANK to auto-download Qwen/Qwen3-ASR-1.7B from Hugging Face (recommended).
# Only set it to a local folder path if you pre-downloaded the model and want offline use,
# e.g.  QWEN_ASR_MODEL_DIR=C:/models/Qwen3-ASR-1.7B  (Windows)  or  /home/you/models/...
QWEN_ASR_MODEL_DIR=
