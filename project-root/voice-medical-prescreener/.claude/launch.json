{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend (FastAPI + uvicorn)",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "backend.app.main:app", "--reload", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "backend-linux (FastAPI + uvicorn)",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "backend.app.main:app", "--reload", "--port", "8001"],
      "port": 8001
    }
  ]
}
